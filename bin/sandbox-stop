#!/usr/bin/env bash
# sandbox-stop <name> [--rm]
# Stop a container. Pass --rm to also delete it and clean up deploy keys.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

USAGE="sandbox-stop <name> [--rm] — stop a container

  --rm   Also delete the container and clean up its deploy key

The stopped container can be brought back with 'sandbox-start <name>'."
maybe_help "$USAGE" "$@"

# Accept `--rm` before or after the name (sandbox-stop --rm foo == sandbox-stop foo --rm).
NAME=""
REMOVE=""
for arg in "$@"; do
  case "$arg" in
    --rm) REMOVE="--rm" ;;
    -*) die "Unknown flag: $arg" ;;
    *) if [[ -z "$NAME" ]]; then NAME="$arg"; else die "Unexpected argument: $arg"; fi ;;
  esac
done
[[ -n "$NAME" ]] || die "Usage: sandbox-stop <name> [--rm]"
CONTAINER=$(container_name "$NAME")

require_vm

# Verify container exists
require_container "$CONTAINER"

# Clean up SSH agent
info "Cleaning up SSH agent..."
ssh_agent_cleanup "$CONTAINER"

# Clean up domain filtering (Squid ACL + NAT rules)
cleanup_container_domain_filter "$CONTAINER"

# Clean up per-container egress rules
info "Cleaning up egress rules..."
CONTAINER_IP=$(get_container_ip "$CONTAINER")
if [[ -n "$CONTAINER_IP" ]]; then
  remove_container_squid_redirect "$CONTAINER_IP"
  cleanup_container_forward_rules "$CONTAINER_IP"
fi

# Remove stale SSH host key to prevent MitmPortForwardingDisabled on restart
SSH_PORT=$(vm_exec "incus config device get ${CONTAINER} ssh-proxy listen 2>/dev/null" | grep -o '[0-9]*$' || true)
if [[ -n "$SSH_PORT" ]]; then
  ssh-keygen -R "[localhost]:${SSH_PORT}" 2>/dev/null || true
fi

# Stop
vm_exec "incus stop '${CONTAINER}' --force 2>/dev/null || true"
ok "Stopped ${CONTAINER}"

# Remove if --rm
if [[ "$REMOVE" == "--rm" ]]; then
  # Clean up deploy key from GitHub
  REPO=$(get_metadata "$CONTAINER" "repo")
  if [[ -n "$REPO" ]]; then
    deploy_key_cleanup "$NAME" "$REPO"
  fi

  vm_exec "incus delete '${CONTAINER}'"
  ok "Deleted ${CONTAINER}"
fi
