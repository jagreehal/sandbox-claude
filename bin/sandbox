#!/usr/bin/env bash
# sandbox <name> [name2...] [flags]
# Session entry point: shell, Claude, or command. Auto-tmux for multiple containers.
#
# Examples:
#   sandbox proj-alpha                        # shell into one
#   sandbox proj-alpha proj-beta              # tmux with shells
#   sandbox proj-alpha --claude               # run claude
#   sandbox proj-alpha proj-beta --claude     # tmux with claude
#   sandbox proj-alpha --codex                # run codex
#   sandbox proj-alpha --cmd "git status"     # run command
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

USAGE="sandbox <name> [name2...] [flags] — open a session in one or more containers

Modes:
  (default)         Interactive shell
  --claude          Run Claude Code
  --codex           Run Codex CLI
  --cmd \"command\"   Run an arbitrary command

Multiple names open a tmux session with one pane per container.

Examples:
  sandbox proj-alpha                       # shell into one
  sandbox proj-alpha proj-beta             # tmux with shells
  sandbox proj-alpha --claude              # run claude
  sandbox proj-alpha --codex               # run codex
  sandbox proj-alpha --cmd \"git status\"    # run a command"
maybe_help "$USAGE" "$@"

# ── Parse args ──────────────────────────────────────────────────────
NAMES=()
MODE="shell" # shell | claude | codex | cmd
CMD=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --claude)
      MODE="claude"
      shift
      ;;
    --codex)
      MODE="codex"
      shift
      ;;
    --cmd)
      [[ -n "${2:-}" ]] || die "--cmd requires a value"
      MODE="cmd"
      CMD="$2"
      shift 2
      ;;
    --*) die "Unknown flag: $1" ;;
    *)
      NAMES+=("$1")
      shift
      ;;
  esac
done

[[ ${#NAMES[@]} -gt 0 ]] || die "Usage: sandbox <name> [name2...] [--claude|--codex] [--cmd \"command\"]"

require_sandbox

# ── Build the command to run in each container ──────────────────────
# build_session_argv populates the SESSION_ARGV array (bash can't return one).
# The direct single-container path execs the array as-is — no eval, no quoting.
# The tmux path needs a single command string per pane, so build_session_cmd
# renders the same array with POSIX-safe single-quoting.
SESSION_ARGV=()
build_session_argv() {
  local name="$1"
  local container
  container=$(container_name "$name")

  SESSION_ARGV=()
  if [[ "$SANDBOX_PLATFORM" == "macos" ]]; then
    SESSION_ARGV+=(orb run -m "${SANDBOX_MACHINE}" sudo)
  fi
  SESSION_ARGV+=(incus exec "${container}"
    --user "${SANDBOX_UID}" --group "${SANDBOX_GID}"
    --cwd "${WORKSPACE_DIR}" --env "HOME=${SANDBOX_USER_HOME}" --)

  case "$MODE" in
    shell) SESSION_ARGV+=(bash --login) ;;
    claude) SESSION_ARGV+=(bash --login -c 'claude --dangerously-skip-permissions') ;;
    codex) SESSION_ARGV+=(bash --login -c 'codex --dangerously-bypass-approvals-and-sandbox') ;;
    cmd) SESSION_ARGV+=(bash --login -c "$CMD") ;;
  esac
}

# Single-quote one argument so any POSIX sh (tmux's command runner) re-parses it
# back to the original literal.
_shquote() {
  local s="${1//\'/\'\\\'\'}"
  printf "'%s'" "$s"
}

build_session_cmd() {
  build_session_argv "$1"
  local out="" a
  for a in "${SESSION_ARGV[@]}"; do out+="$(_shquote "$a") "; done
  printf '%s' "${out% }"
}

# ── Validate all containers exist and are running ───────────────────
for name in "${NAMES[@]}"; do
  container=$(container_name "$name")
  require_container "$container"
  state=$(vm_exec "incus info ${container} 2>/dev/null | grep 'Status:' | awk '{print \$2}'" || true)
  if [[ "$state" != "RUNNING" ]]; then
    die "Container '${container}' is ${state}, not running. Run 'sandbox-start ${name}' to restart it."
  fi
done

# ── Single container: direct session ────────────────────────────────
if [[ ${#NAMES[@]} -eq 1 ]]; then
  build_session_argv "${NAMES[0]}"
  exec "${SESSION_ARGV[@]}"
fi

# ── Multiple containers: tmux ───────────────────────────────────────
require_command tmux

SESSION="sandbox-agents"
tmux kill-session -t "$SESSION" 2>/dev/null || true

# First pane
FIRST_CMD=$(build_session_cmd "${NAMES[0]}")
tmux new-session -d -s "$SESSION" -n "agents" "$FIRST_CMD"

# Remaining panes
for ((i = 1; i < ${#NAMES[@]}; i++)); do
  PANE_CMD=$(build_session_cmd "${NAMES[$i]}")
  tmux split-window -t "$SESSION" "$PANE_CMD"
  tmux select-layout -t "$SESSION" tiled
done

tmux attach-session -t "$SESSION"
